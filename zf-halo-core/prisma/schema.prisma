// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ENUMS
// ==========================================

/// User roles according to ZF-HALO requirements (22% rubric)
enum Role {
  USER // Request loans, view catalog
  MANAGER // Approve team loans (Manager/Lead)
  ADMIN // Full asset and loan management (Asset Administrator)
  AUDITOR // Read-only access + export
}

// ==========================================
// MODELS
// ==========================================

/// User model with secure password storage and RBAC
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  company      String?
  role         Role     @default(USER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Future relations
  loans         Loan[]                 @relation("RequestedLoans")
  approvedLoans Loan[]                 @relation("ApprovedLoans")
  notifications InternalNotification[]

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@map("users")
}

/// Request for a new account (Pending Admin Approval)
model AccountRequest {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  company      String?
  status       String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([email])
  @@map("account_requests")
}

// ==========================================
// ASSET ENUMS
// ==========================================

/// Machine operational status (from ZF ADAS catalog)
enum MachineStatus {
  OPERATIVE
  IN_MAINTENANCE
  OUT_OF_SERVICE
  CALIBRATION
  LOANED
  DECOMMISSIONED
  IN_TRANSIT
  IN_CUSTOMS
  UNDER_EVALUATION
  CANNIBALIZED
  IMPAIRMENT
}

/// Purchase origin type
enum PurchaseType {
  IMPORT
  NATIONAL
}

/// National purchase sub-type
enum NationalType {
  OWN
  TEMPORARY
  DEFINITIVE
}

// ==========================================
// ASSET MODEL
// ==========================================

/// Asset catalog based on ZF ADAS Excel columns
model Asset {
  id              String        @id @default(uuid())
  identifier      Int           @unique
  area            String
  subArea         String        @map("sub_area")
  category        String
  initialQuantity Int?          @map("initial_quantity") // Only for spare parts
  currentQuantity Int?          @map("current_quantity") // Only for spare parts
  projectName     String        @map("project_name")
  machineName     String        @map("machine_name")
  tag             String        @unique // QR code
  serialNumber    String        @unique @map("serial_number")
  model           String
  brand           String
  year            Int?
  customsDocument String?       @map("customs_document") // Pedimento
  invoice         String? // Factura
  commercialValue Decimal       @map("commercial_value")
  purchaseDate    DateTime?     @map("purchase_date")
  description     String?
  comments        String?
  purchaseType    PurchaseType  @map("purchase_type")
  nationalType    NationalType? @map("national_type")
  machineStatus   MachineStatus @default(OPERATIVE) @map("machine_status")
  assetType       AssetType     @default(SERIALIZED) @map("asset_type")
  isPurchased     Boolean       @default(false) @map("is_purchased")
  isActive        Boolean       @default(true) @map("is_active")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  loans Loan[]

  @@index([tag])
  @@index([area])
  @@index([machineStatus])
  @@index([isActive])
  @@index([identifier])
  @@map("assets")
}

// ==========================================
// LOANS & NOTIFICATIONS ENUMS
// ==========================================

enum LoanStatus {
  REQUESTED
  AUTHORIZED
  CHECKED_OUT
  RETURNED
}

enum AssetType {
  SERIALIZED
  BULK
}

// ==========================================
// LOANS & NOTIFICATIONS MODELS
// ==========================================

model Destination {
  id        String   @id @default(uuid())
  name      String   @unique
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  loans     Loan[]

  @@map("destinations")
}

model Loan {
  id                  String     @id @default(uuid())
  folio               String     @unique // SAL-2026-XXXX
  status              LoanStatus @default(REQUESTED)
  quantity            Int        @default(1) // >1 only for BULK
  estimatedReturnDate DateTime   @map("estimated_return_date")
  departureDate       DateTime?  @map("departure_date")
  actualReturnDate    DateTime?  @map("actual_return_date")
  comments            String?

  // Relations
  requesterId   String      @map("requester_id")
  requester     User        @relation("RequestedLoans", fields: [requesterId], references: [id])
  authorizerId  String?     @map("authorizer_id")
  authorizer    User?       @relation("ApprovedLoans", fields: [authorizerId], references: [id])
  assetId       String      @map("asset_id")
  asset         Asset       @relation(fields: [assetId], references: [id])
  destinationId String      @map("destination_id")
  destination   Destination @relation(fields: [destinationId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([requesterId])
  @@index([assetId])
  @@index([folio])
  @@map("loans")
}

model InternalNotification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  status    String   @default("UNREAD") // UNREAD, READ
  type      String   @default("INFO") // INFO, ALERT, ESCALATION
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, status])
  @@map("internal_notifications")
}
